<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MLB Debut Pitchers · 2020–Present · 2+ WAR Seasons</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0a0c0f;
  --ink2: #141820;
  --ink3: #1e2530;
  --line: #2a3140;
  --line2: #374151;
  --chalk: #e8edf4;
  --chalk2: #9ba8bc;
  --chalk3: #6b7a8f;
  --gold: #f0c040;
  --gold-dim: #b8922e;
  --blue: #4a9eff;
  --blue-dim: #2d6abf;
  --green: #3dba7a;
  --green-dim: #2a8a57;
  --red: #f0604a;
  --red-dim: #b84438;
  --teal: #38c8b8;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--ink);
  color: var(--chalk);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
}

/* ── HEADER ── */
.site-header {
  border-bottom: 1px solid var(--line);
  padding: 28px 32px 24px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20px;
  flex-wrap: wrap;
  background: linear-gradient(180deg, #0d1219 0%, var(--ink) 100%);
}
.header-left {}
.eyebrow {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 6px;
}
h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 800;
  color: var(--chalk);
  line-height: 1.1;
  letter-spacing: -0.02em;
}
h1 span { color: var(--gold); }
.header-sub {
  font-size: 13px;
  color: var(--chalk3);
  margin-top: 6px;
  font-weight: 300;
}
.stat-pills {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.stat-pill {
  background: var(--ink3);
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 8px 16px;
  text-align: center;
}
.stat-pill .val {
  font-family: 'Syne', sans-serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--gold);
  display: block;
  line-height: 1;
}
.stat-pill .lbl {
  font-size: 10px;
  color: var(--chalk3);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 3px;
}

/* ── DATA NOTE ── */
.data-note {
  background: #111620;
  border-left: 3px solid var(--gold-dim);
  padding: 10px 20px;
  font-size: 11.5px;
  color: var(--chalk3);
  line-height: 1.6;
}
.data-note strong { color: var(--gold); }

/* ── CONTROLS ── */
.controls {
  padding: 16px 32px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  border-bottom: 1px solid var(--line);
  background: var(--ink2);
  position: sticky;
  top: 0;
  z-index: 100;
}
.ctrl-group {
  display: flex;
  align-items: center;
  gap: 6px;
}
.ctrl-label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--chalk3);
}
.pill-btn {
  background: var(--ink3);
  border: 1px solid var(--line);
  color: var(--chalk3);
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  padding: 5px 13px;
  border-radius: 20px;
  cursor: pointer;
  transition: all 0.15s;
  letter-spacing: 0.04em;
}
.pill-btn:hover { border-color: var(--gold-dim); color: var(--gold); }
.pill-btn.active { background: var(--gold); border-color: var(--gold); color: var(--ink); font-weight: 600; }
select, input[type=text] {
  background: var(--ink3);
  border: 1px solid var(--line);
  color: var(--chalk);
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  padding: 5px 10px;
  border-radius: 6px;
  outline: none;
  cursor: pointer;
}
select:focus, input:focus { border-color: var(--gold-dim); }
input[type=text]::placeholder { color: var(--chalk3); }
.divider { width: 1px; height: 24px; background: var(--line); }

.count-badge {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  color: var(--chalk3);
  margin-left: auto;
}
.count-badge span { color: var(--gold); font-weight: 600; }

/* ── SORT HEADER ── */
.sort-bar {
  padding: 8px 32px;
  display: flex;
  gap: 6px;
  border-bottom: 1px solid var(--line);
  background: var(--ink2);
}
.sort-label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  text-transform: uppercase;
  color: var(--chalk3);
  letter-spacing: 0.1em;
  margin-right: 4px;
  align-self: center;
}
.sort-btn {
  background: none;
  border: none;
  color: var(--chalk3);
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  padding: 3px 10px;
  border-radius: 4px;
  cursor: pointer;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  transition: all 0.12s;
}
.sort-btn:hover { color: var(--chalk); background: var(--ink3); }
.sort-btn.active { color: var(--gold); }

/* ── PITCHER CARDS ── */
.grid {
  padding: 24px 32px;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
  gap: 16px;
}

.card {
  background: var(--ink2);
  border: 1px solid var(--line);
  border-radius: 12px;
  overflow: hidden;
  transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  cursor: pointer;
}
.card:hover {
  border-color: var(--gold-dim);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}

/* Card header */
.card-head {
  padding: 14px 16px 12px;
  background: var(--ink3);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}
.card-name {
  font-family: 'Syne', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--chalk);
  line-height: 1.2;
}
.card-meta {
  font-size: 11.5px;
  color: var(--chalk3);
  margin-top: 3px;
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
}
.hand-badge {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  font-weight: 500;
  padding: 1px 6px;
  border-radius: 4px;
  background: var(--ink);
  border: 1px solid var(--line);
  color: var(--chalk2);
}
.war-badge {
  text-align: right;
  flex-shrink: 0;
}
.war-num {
  font-family: 'Syne', sans-serif;
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--gold);
  line-height: 1;
  display: block;
}
.war-sub {
  font-family: 'DM Mono', monospace;
  font-size: 9.5px;
  color: var(--chalk3);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* MLB Seasons */
.mlb-section {
  padding: 10px 16px;
  border-bottom: 1px solid var(--line);
  background: #0f141c;
}
.section-label {
  font-family: 'DM Mono', monospace;
  font-size: 9.5px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--blue);
  margin-bottom: 7px;
  display: flex;
  align-items: center;
  gap: 5px;
}
.section-label::before {
  content: '';
  display: inline-block;
  width: 14px;
  height: 1px;
  background: var(--blue);
}
.season-row {
  display: flex;
  align-items: baseline;
  gap: 10px;
  padding: 3px 0;
  font-size: 12px;
  border-bottom: 1px solid #1a2030;
}
.season-row:last-child { border-bottom: none; }
.season-yr {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  color: var(--chalk2);
  width: 36px;
  flex-shrink: 0;
}
.season-stats {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  align-items: baseline;
}
.sstat {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
}
.sstat .sv { font-weight: 500; color: var(--chalk); }
.sstat .sk { color: var(--chalk3); font-size: 10px; }
.season-note {
  font-size: 11px;
  color: var(--chalk3);
  margin-left: auto;
  font-style: italic;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 140px;
}
.qual-star {
  color: var(--gold);
  font-size: 10px;
  font-family: 'DM Mono', monospace;
  font-style: normal;
  background: rgba(240,192,64,0.1);
  padding: 1px 5px;
  border-radius: 3px;
}

/* Minor League Table */
.minor-section {
  padding: 10px 16px 14px;
}
.minor-table {
  width: 100%;
  border-collapse: collapse;
  font-family: 'DM Mono', monospace;
  font-size: 11px;
}
.minor-table th {
  color: var(--chalk3);
  text-align: right;
  padding: 3px 6px 5px;
  font-size: 10px;
  font-weight: 500;
  border-bottom: 1px solid var(--line);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.minor-table th:first-child { text-align: left; }
.minor-table td {
  padding: 4px 6px;
  text-align: right;
  border-bottom: 1px solid #171e28;
  color: var(--chalk2);
  font-size: 11px;
}
.minor-table td:first-child { text-align: left; }
.minor-table tr:last-child td { border-bottom: none; }
.minor-table tr:hover td { background: rgba(255,255,255,0.02); }

/* Year group header row */
.yr-group-row td {
  background: #0e1520;
  color: var(--chalk3);
  font-size: 10px;
  padding: 3px 6px 2px;
  border-bottom: none;
  border-top: 1px solid var(--line);
  letter-spacing: 0.06em;
}
.yr-group-row:first-child td { border-top: none; }
.yr-group-row td:first-child {
  font-family: 'DM Mono', monospace;
  font-weight: 600;
  color: var(--gold);
  font-size: 10.5px;
}
.yr-total {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--chalk3);
}
.yr-total strong {
  color: var(--chalk2);
  font-weight: 600;
}

/* Stint rows indented under year */
.stint-row td:first-child { padding-left: 10px; }
.ip-bar-cell { position: relative; }
.ip-bar {
  display: inline-block;
  height: 3px;
  background: var(--blue-dim);
  border-radius: 2px;
  margin-left: 4px;
  vertical-align: middle;
  opacity: 0.6;
}

.lvl-tag {
  display: inline-block;
  padding: 1px 6px;
  border-radius: 3px;
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.06em;
  margin-right: 4px;
}
.lvl-Rk  { background: #1a2a1a; color: #5a9a5a; border: 1px solid #2a4a2a; }
.lvl-A   { background: #1a1a2a; color: #5a6aaa; border: 1px solid #2a2a4a; }
.lvl-Ap  { background: #1a1a2a; color: #6a7abb; border: 1px solid #2a2a4a; }
.lvl-AA  { background: #22202a; color: #8a7aca; border: 1px solid #3a2a4a; }
.lvl-AAA { background: #2a1a1a; color: #ca7a5a; border: 1px solid #4a2a2a; }
.lvl-Alt { background: #1a2225; color: #4a9a9a; border: 1px solid #2a3a3a; }

.v-elite { color: #4a9eff; font-weight: 600; }
.v-great { color: var(--green); font-weight: 500; }
.v-good  { color: var(--chalk); }
.v-poor  { color: var(--red); }

.no-minors {
  color: var(--chalk3);
  font-size: 11.5px;
  font-style: italic;
  padding: 6px 0;
  text-align: center;
}

/* No results */
.no-results {
  grid-column: 1 / -1;
  text-align: center;
  padding: 80px 20px;
  color: var(--chalk3);
  font-family: 'Syne', sans-serif;
  font-size: 1.2rem;
}

/* Legend */
.legend {
  padding: 12px 32px;
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  border-bottom: 1px solid var(--line);
  align-items: center;
  background: #0c1018;
}
.legend-title {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--chalk3);
}
.legend-items {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}
.li {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: 'DM Mono', monospace;
  font-size: 10.5px;
}
.li-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
}
.legend-sep {
  height: 1px;
  width: 1px;
  background: var(--line);
}

/* Footer */
footer {
  padding: 24px 32px;
  border-top: 1px solid var(--line);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
  font-size: 11.5px;
  color: var(--chalk3);
  background: var(--ink2);
}
footer a { color: var(--blue); text-decoration: none; }
footer a:hover { text-decoration: underline; }

/* Expand toggle */
.expand-btn {
  display: block;
  width: 100%;
  background: none;
  border: none;
  border-top: 1px solid var(--line);
  color: var(--chalk3);
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  padding: 6px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  transition: all 0.15s;
}
.expand-btn:hover { background: var(--ink3); color: var(--chalk2); }

.card.collapsed .mlb-section,
.card.collapsed .minor-section { display: none; }

/* responsive */
@media (max-width: 600px) {
  .site-header { padding: 20px 16px 18px; }
  .controls { padding: 12px 16px; }
  .grid { padding: 16px; gap: 12px; grid-template-columns: 1fr; }
  .sort-bar { padding: 8px 16px; }
  .legend { padding: 10px 16px; }
  footer { padding: 16px; }
}
</style>
</head>
