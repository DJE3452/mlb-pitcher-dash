// ── Average age by level (MLB-wide historical norms for starting pitchers) ──
// Source: FanGraphs/Baseball Reference population averages across affiliated MiLB
const AVG_AGE = {
  'Rk':  19.5,
  'A-':  21.0,
  'A':   22.0,
  'A+':  22.5,
  'AA':  23.5,
  'AAA': 25.0,
  'Alt': 23.0,  // COVID alt sites — mixed ages, use rough average
};

function ageVsAvg(lvl, age) {
  const avg = AVG_AGE[lvl];
  if (avg === undefined) return null;
  const delta = age - avg;
  return { delta, avg };
}

function ageTag(lvl, age) {
  const r = ageVsAvg(lvl, age);
  if (!r) return '';
  const { delta, avg } = r;
  const sign = delta < 0 ? '−' : delta > 0 ? '+' : '±';
  const abs = Math.abs(delta).toFixed(1).replace(/\.0$/, '');
  const label = delta === 0 ? `±0 vs avg ${avg}` : `${sign}${abs} vs avg ${avg}`;

  let color, title;
  if (delta <= -1.5) {
    color = '#3dba7a'; title = 'Significantly younger than avg for this level';
  } else if (delta < 0) {
    color = '#6fcf97'; title = 'Younger than avg for this level';
  } else if (delta === 0) {
    color = 'var(--chalk3)'; title = 'At avg age for this level';
  } else if (delta <= 1.5) {
    color = 'var(--chalk3)'; title = 'Slightly older than avg for this level';
  } else {
    color = '#e07060'; title = 'Older than avg for this level';
  }

  return `<span title="${title}" style="font-family:'DM Mono',monospace;font-size:9px;color:${color};margin-left:4px;opacity:0.9">${label}</span>`;
}

// ── Helpers ──
function colorFIP(v) {
  if (v<2.50) return 'v-elite'; if (v<3.20) return 'v-great'; if (v>4.20) return 'v-poor'; return 'v-good';
}
function colorK(s) {
  if (!s || s==='—' || s.startsWith('~')) return '';
  const v=parseFloat(s); if (v>33) return 'v-elite'; if (v>27) return 'v-great'; if (v<21) return 'v-poor'; return 'v-good';
}
function colorBB(s) {
  if (!s || s==='—' || s.startsWith('~')) return '';
  const v=parseFloat(s); if (v<6) return 'v-elite'; if (v<9) return 'v-great'; if (v>11) return 'v-poor'; return 'v-good';
}
function colorSLG(s) {
  if (!s || s==='—' || s.startsWith('~')) return '';
  const v=parseFloat(s); if (v<.220) return 'v-elite'; if (v<.270) return 'v-great'; if (v>.330) return 'v-poor'; return 'v-good';
}
function fmtStat(s) {
  if (!s || s==='—') return '<span style="color:var(--chalk3);font-size:10px">—</span>';
  if (s.startsWith('~')) return `<span style="color:var(--chalk3)" title="Estimated">${s}</span>`;
  return s;
}
function lvlClass(l) {
  if (l==='Rk') return 'lvl-Rk';
  if (l==='A') return 'lvl-A';
  if (l==='A+') return 'lvl-Ap';
  if (l==='AA') return 'lvl-AA';
  if (l==='AAA') return 'lvl-AAA';
  return 'lvl-Alt';
}

function buildCard(p) {
  const mlbRows = p.mlb.map(s => {
    const star = s.note.startsWith('⭐') ? `<span class="qual-star">⭐ WAR ${s.war}</span>` : `<span style="color:var(--chalk3);font-family:'DM Mono',monospace;font-size:10px">WAR ${s.war}</span>`;
    const cleanNote = s.note.replace('⭐ ','');
    return `<div class="season-row">
      <span class="season-yr">${s.yr}</span>
      <div class="season-stats">
        <span class="sstat"><span class="sk">ERA </span><span class="sv">${s.era}</span></span>
        <span class="sstat"><span class="sk">FIP </span><span class="sv">${s.fip}</span></span>
        <span class="sstat"><span class="sk">IP </span><span class="sv">${s.ip}</span></span>
        ${star}
      </div>
      <span class="season-note" title="${cleanNote}">${cleanNote}</span>
    </div>`;
  }).join('');

  let minorContent;
  if (p.noMinorNote) {
    minorContent = `<div class="no-minors">${p.noMinorNote}</div>`;
  } else if (!p.minors || p.minors.length===0) {
    minorContent = `<div class="no-minors">No affiliated MiLB data available</div>`;
  } else {
    // Group stints by year
    const byYear = {};
    p.minors.forEach(m => {
      if (!byYear[m.yr]) byYear[m.yr] = [];
      byYear[m.yr].push(m);
    });

    // Max IP in any single stint for bar scaling
    const maxIP = Math.max(...p.minors.map(m => parseFloat(m.ip)));

    let rows = '';
    Object.keys(byYear).sort().forEach(yr => {
      const stints = byYear[yr];
      const totalIP = stints.reduce((s,m) => s + parseFloat(m.ip), 0);
      const totalIPStr = totalIP % 1 === 0 ? totalIP.toFixed(0) : totalIP.toFixed(1);
      const multiLevel = stints.length > 1;

      // Year header row (only if multi-level or always for clarity)
      rows += `<tr class="yr-group-row">
        <td colspan="2">${yr} <span style="color:var(--chalk3);font-weight:400;font-size:9.5px">— Age ${stints[0].age}</span></td>
        <td colspan="6"><span class="yr-total">${multiLevel ? `<strong>${stints.length}</strong> levels · ` : ''}<strong>${totalIPStr}</strong> total IP</span></td>
      </tr>`;

      stints.forEach(m => {
        const barWidth = Math.round((parseFloat(m.ip) / maxIP) * 38);
        rows += `<tr class="stint-row">
          <td><span class="lvl-tag ${lvlClass(m.lvl)}">${m.lvl}</span><span style="color:var(--chalk3)">${m.org}</span>${ageTag(m.lvl, m.age)}</td>
          <td class="ip-bar-cell">
            ${m.ip}<span class="ip-bar" style="width:${barWidth}px"></span>
          </td>
          <td class="${colorFIP(m.fip)}">${m.fip}</td>
          <td class="${colorK(m.kp)}">${fmtStat(m.kp)}</td>
          <td class="${colorBB(m.bp)}">${fmtStat(m.bp)}</td>
          <td class="${colorSLG(m.slg)}">${fmtStat(m.slg)}</td>
        </tr>`;
      });
    });

    minorContent = `<table class="minor-table">
      <thead><tr>
        <th>Level / Org</th><th>IP</th>
        <th>FIP</th><th>K%</th><th>BB%</th><th>SLG-A</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
  }

  return `<div class="card" data-debut="${p.debut}" data-war="${p.bestWAR}" data-name="${p.name.toLowerCase()}" data-hand="${p.hand||''}">
    <div class="card-head">
      <div>
        <div class="card-name">${p.name}</div>
        <div class="card-meta">
          <span class="hand-badge">${p.hand||'—'}</span>
          <span>${p.team}</span>
          <span>·</span>
          <span>Debut <strong>${p.debut}</strong></span>
        </div>
      </div>
      <div class="war-badge">
        <span class="war-num">${p.bestWAR}</span>
        <span class="war-sub">best fWAR (${p.bestYear})</span>
      </div>
    </div>
    <div class="mlb-section">
      <div class="section-label">MLB Seasons ≥ 2.0 WAR</div>
      ${mlbRows}
    </div>
    <div class="minor-section">
      <div class="section-label" style="color:var(--green)">Minor League Stats by Level &amp; Age</div>
      ${minorContent}
    </div>
  </div>`;
}

let sortMode = 'war';

function render() {
  const activeYear = document.querySelector('.pill-btn.active')?.dataset.year || 'all';
  const minWAR = parseFloat(document.getElementById('warFilter').value);
  const handVal = document.getElementById('handFilter').value;
  const search = document.getElementById('searchBox').value.toLowerCase().trim();

  let filtered = PITCHERS.filter(p => {
    if (p._skip || !p.hand) return false;
    if (activeYear !== 'all' && p.debut !== parseInt(activeYear)) return false;
    if (p.bestWAR < minWAR) return false;
    if (handVal !== 'all' && p.hand !== handVal) return false;
    if (search && !p.name.toLowerCase().includes(search)) return false;
    return true;
  });

  if (sortMode === 'war') filtered.sort((a,b) => b.bestWAR - a.bestWAR);
  else if (sortMode === 'debut') filtered.sort((a,b) => a.debut - b.debut || b.bestWAR - a.bestWAR);
  else if (sortMode === 'name') filtered.sort((a,b) => a.name.localeCompare(b.name));

  const grid = document.getElementById('pitcherGrid');
  grid.innerHTML = filtered.length === 0
    ? '<div class="no-results">No pitchers match these filters.</div>'
    : filtered.map(buildCard).join('');

  document.getElementById('countSpan').textContent = filtered.length;

  // Update header stats
  const allValid = PITCHERS.filter(p=>!p._skip && p.hand);
  document.getElementById('totalPitchers').textContent = allValid.length;
  document.getElementById('totalSeasons').textContent = allValid.reduce((s,p)=>(p.mlb||[]).filter(m=>m.war>=2.0).length+s,0);
  document.getElementById('topWAR').textContent = Math.max(...allValid.map(p=>p.bestWAR)).toFixed(1);
}

// Event listeners
document.querySelectorAll('.pill-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.pill-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    render();
  });
});
document.getElementById('warFilter').addEventListener('change', render);
document.getElementById('handFilter').addEventListener('change', render);
document.getElementById('searchBox').addEventListener('input', render);

document.querySelectorAll('.sort-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.sort-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    sortMode = btn.dataset.sort;
    render();
  });
});

render();
</script>
